# Dashboard auth password
DASHBOARD_PASSWORD=quark-dev

# Path to Quark workspace (local mode)
QUARK_WORKSPACE=/Users/quark/.openclaw/workspace

# --- Remote mode (Vercel deployment) ---
# Set these on Vercel to enable hash-polling instead of SSE

# NEXT_PUBLIC_IS_REMOTE=true
# NEXT_PUBLIC_SNAPSHOT_URL=https://<macbook-tailscale-funnel-url>
# NEXT_PUBLIC_SNAPSHOT_API_KEY=<same-as-SNAPSHOT_API_KEY>

# Server-side snapshot config (also needed on Vercel for parameterized API routes)
# SNAPSHOT_URL=https://<macbook-tailscale-funnel-url>
# SNAPSHOT_API_KEY=<your-api-key>
